{
  "name": "my-one-pager",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check .",
    "check:ci": "biome check .",
    "lighthouse": "lhci autorun"
  },
  "engines": {
    "node": ">=26",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "bootstrap": "^5.3.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@lhci/cli": "^0.15.1",
    "lint-staged": "^17.0.4",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.99.0",
    "vite": "^8.0.10"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,scss,html}": [
      "biome check --write"
    ]
  }
}
